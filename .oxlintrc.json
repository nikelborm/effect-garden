{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "jsPlugins": ["./one-offs/oxlint-plugin-effect-imports/dist/index.js"],
  "rules": {
    "effect-imports/named-to-namespace": "error"
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/dist-types/**",
    "**/.next/**",
    "**/build/**",
    "**/built/**",
    "**/.turbo/**"
  ]
}
