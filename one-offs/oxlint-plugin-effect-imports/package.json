{
  "name": "oxlint-plugin-effect-imports",
  "type": "module",
  "version": "0.1.0",
  "description": "Oxlint plugin to enforce namespace imports from Effect package subpaths",
  "keywords": [
    "oxlint",
    "oxlint-plugin",
    "effect",
    "effect-ts",
    "lint",
    "imports"
  ],
  "homepage": "https://github.com/nikelborm/effect-garden/tree/main/one-offs/oxlint-plugin-effect-imports#readme",
  "bugs": {
    "url": "https://github.com/nikelborm/effect-garden/issues",
    "email": "evadev@duck.com"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nikelborm/effect-garden.git",
    "directory": "one-offs/oxlint-plugin-effect-imports"
  },
  "author": {
    "name": "nikelborm",
    "email": "evadev@duck.com",
    "url": "https://github.com/nikelborm"
  },
  "contributors": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "maintainers": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "exports": {
    ".": {
      "source": "./index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "index.ts",
    "package.json",
    "!**/*.spec.*",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "bun build ./index.ts --outfile ./dist/index.js --format esm",
    "test": "vitest --run",
    "test:watch": "vitest --watch"
  },
  "peerDependencies": {
    "oxlint": ">=0.15.0"
  },
  "devDependencies": {
    "@evadev/tsconfig": "workspace:^",
    "@typescript/native-preview": "catalog:",
    "eslint": "^10.4.0",
    "oxlint": "latest",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
