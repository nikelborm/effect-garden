{
  "name": "oxlint-plugin-effect-imports",
  "type": "module",
  "version": "1.0.0",
  "description": "Oxlint plugin to enforce namespace imports from Effect package subpaths",
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@evadev/tsconfig": "workspace:^",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "oxlint": "catalog:",
    "ts-namespace-import": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/nikelborm/effect-garden/tree/main/one-offs/oxlint-plugin-effect-imports#readme",
  "bugs": {
    "url": "https://github.com/nikelborm/effect-garden/issues",
    "email": "evadev@duck.com"
  },
  "keywords": [
    "oxlint",
    "oxlint-plugin",
    "effect",
    "plugin",
    "effect-ts",
    "lint",
    "imports"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nikelborm/effect-garden.git",
    "directory": "one-offs/oxlint-plugin-effect-imports"
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch --preserveWatchOutput false",
    "prepack": "rm -rf dist dist-types && bun run build",
    "test": "vitest --run",
    "test:watch": "vitest --watch"
  },
  "author": {
    "name": "nikelborm",
    "email": "evadev@duck.com",
    "url": "https://github.com/nikelborm"
  },
  "contributors": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "maintainers": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "peerDependencies": {
    "oxlint": ">=1.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist-types/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./*.ts": "./src/*.ts",
    "./*": {
      "types": "./dist-types/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist-types/index.d.ts",
  "files": [
    "dist-types",
    "dist",
    "index.ts",
    "package.json",
    "!**/*.spec.*",
    "!**/*.tsbuildinfo",
    "!**/scratchpad.*"
  ]
}
