{
  "name": "gitdl",
  "type": "module",
  "version": "0.2.6",
  "description": "Download any directory at any depth from any repo on GitHub on any git ref",
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@evadev/tsconfig": "workspace:^",
    "@rollup/plugin-commonjs": "catalog:",
    "@rollup/plugin-json": "catalog:",
    "@rollup/plugin-node-resolve": "catalog:",
    "@rollup/plugin-terser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-visualizer": "catalog:",
    "ts-namespace-import": "catalog:",
    "ts-patch": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@effect/cli": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "effect": "catalog:"
  },
  "dependencies": {
    "@evadev/effect-helpers": "workspace:^",
    "@octokit/core": "catalog:",
    "@octokit/request-error": "catalog:",
    "@octokit/types": "catalog:",
    "@total-typescript/ts-reset": "catalog:",
    "@types/tar-fs": "catalog:",
    "effect-errors": "catalog:",
    "outdent": "catalog:",
    "tar-fs": "catalog:",
    "tsafe": "catalog:"
  },
  "homepage": "https://github.com/nikelborm/effect-garden/tree/main/packages/gitdl#readme",
  "bugs": {
    "url": "https://github.com/nikelborm/effect-garden/issues",
    "email": "evadev@duck.com"
  },
  "keywords": [
    "github",
    "git",
    "octokit",
    "github-api",
    "folder",
    "scraper",
    "downloader",
    "download",
    "extract",
    "tarball",
    "targz",
    "directory"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nikelborm/effect-garden.git",
    "directory": "packages/gitdl"
  },
  "scripts": {
    "build": "./scripts/build.sh",
    "coverage": "vitest run --coverage",
    "doc": "./scripts/generate_docs.sh",
    "docs": "./scripts/generate_docs.sh",
    "print-important-ts-files": "find . -type f -name '*.ts' |grep -vE '^./(node_modules|tmp|dist|(vite\\.config|.*\\.spec|scratchpad)\\.ts)'",
    "scratchpad": "node --use-strict --env-file=.env ./scratchpad.ts",
    "start": "node --env-file=.env ./gitdl.ts",
    "test": "vitest --typecheck --watch",
    "test-jsr": "tspc && jsr publish --dry-run",
    "test-once": "vitest --run",
    "watch-docs": "find src/ cli.ts index.ts errors.ts ./scripts/generate_docs.sh | entr -can ./scripts/generate_docs.sh"
  },
  "author": {
    "name": "nikelborm",
    "email": "evadev@duck.com",
    "url": "https://github.com/nikelborm"
  },
  "contributors": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "maintainers": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist-types/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./*.ts": "./src/*.ts",
    "./*": {
      "types": "./dist-types/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist-types/index.d.ts",
  "bin": {
    "dgit": "dist/gitdl.js",
    "dl-git": "dist/gitdl.js",
    "dlgit": "dist/gitdl.js",
    "gdl": "dist/gitdl.js",
    "git-dl": "dist/gitdl.js",
    "git-dlp": "dist/gitdl.js",
    "gitd": "dist/gitdl.js",
    "gitdl": "dist/gitdl.js"
  },
  "files": [
    "dist",
    "dist-types",
    "index.ts",
    "cli.ts",
    "errors.ts",
    "template.env",
    "src",
    "!dist/minified",
    "!**/*.tsbuildinfo",
    "!**/*.spec.*",
    "!**/scratchpad.*"
  ]
}
