{
  "name": "bliss-audio-ts",
  "type": "module",
  "version": "0.1.8",
  "description": "TypeScript bindings (bun) for bliss-audio, a music analysis library producing fixed-length feature vectors from audio files to find similar songs and build automatic playlists",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@effect/language-service": "catalog:",
    "@nikelborm/tsconfig": "workspace:*",
    "@stryker-mutator/api": "catalog:",
    "@stryker-mutator/core": "catalog:",
    "@stryker-mutator/instrumenter": "catalog:",
    "@stryker-mutator/vitest-runner": "catalog:",
    "numpy-ts": "catalog:",
    "ts-namespace-import": "catalog:",
    "ts-patch": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@types/bun": "catalog:"
  },
  "homepage": "https://github.com/nikelborm/effect-garden/tree/main/packages/bliss-audio-ts#readme",
  "bugs": {
    "url": "https://github.com/nikelborm/effect-garden/issues",
    "email": "evadev@duck.com"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nikelborm/effect-garden.git",
    "directory": "packages/bliss-audio-ts"
  },
  "scripts": {
    "build": "bun build:ts && bun build:native",
    "build:native": "cd native && cargo build --release",
    "build:native-debug": "cd native && cargo build",
    "build:ts": "tsc",
    "format": "bun format:ts && bun format:native",
    "format:native": "cd native && cargo fmt",
    "format:ts": "biome check --write --unsafe .",
    "prepack": "rm -rf dist dist-types && bun build:ts",
    "test": "bun --bun run vitest",
    "test:stryker": "bun --bun run stryker run stryker.conf.js",
    "typecheck": "tsc --noEmit"
  },
  "author": {
    "name": "nikelborm",
    "email": "evadev@duck.com",
    "url": "https://github.com/nikelborm"
  },
  "contributors": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "maintainers": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist-types/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./*.ts": "./src/*.ts",
    "./*": {
      "types": "./dist-types/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist-types/index.d.ts",
  "files": [
    "dist-types",
    "dist",
    "native/target/release/libbliss_native.so",
    "index.ts",
    "package.json",
    "src",
    "!examples",
    "examples/*.ts",
    "!**/*.spec.*",
    "!**/*.test.*",
    "!**/*.tsbuildinfo",
    "!**/scratchpad.*"
  ],
  "patchedDependencies": {
    "@stryker-mutator/instrumenter@9.6.1": "patches/@stryker-mutator%2Finstrumenter@9.6.1.patch"
  }
}
