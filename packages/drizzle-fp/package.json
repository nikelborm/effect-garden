    }
  ],
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist-types/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./*.ts": "./src/*.ts",
    "./*": {
      "types": "./dist-types/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist-types/index.d.ts",
  "files": [
    "dist-types",
    "dist",
    "index.ts",
    "package.json",
    "src",
    "!**/*.spec.*",
    "!**/*.tsbuildinfo",
    "!**/scratchpad.*"
  ]
}
