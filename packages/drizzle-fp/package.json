    "ts-namespace-import": "catalog:",
    "ts-patch": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  },
  "dependencies": {
    "@nevware21/ts-utils": "catalog:",
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "type-fest": "catalog:"
  },
  "homepage": "https://github.com/nikelborm/effect-garden/tree/main/packages/drizzle-fp#readme",
  "bugs": {
    "url": "https://github.com/nikelborm/effect-garden/issues",
