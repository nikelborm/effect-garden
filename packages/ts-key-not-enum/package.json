{
  "name": "ts-key-not-enum",
  "type": "module",
  "version": "1.0.8",
  "description": "Keyboard events have .key string property. This package allows type-safe comparison of that property with non-printable values",
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@microsoft/tsdoc": "catalog:",
    "@nikelborm/tsconfig": "workspace:*",
    "@types/bun": "^1.3.14",
    "@types/unist": "catalog:",
    "effect": "catalog:",
    "effect-mdx": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-jsdoc": "catalog:",
    "ts-namespace-import": "catalog:",
    "ts-patch": "catalog:",
    "ts-pattern": "catalog:",
    "typescript": "catalog:",
    "unified": "catalog:"
  },
  "homepage": "https://github.com/nikelborm/effect-garden/tree/main/packages/ts-key-not-enum#readme",
  "bugs": {
    "url": "https://github.com/nikelborm/effect-garden/issues",
    "email": "evadev@duck.com"
  },
  "keywords": [
    "typescript",
    "javascript",
    "keycodes",
    "key",
    "enum",
    "ts",
    "event.which",
    "event.key",
    "event.keycode"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nikelborm/effect-garden.git",
    "directory": "packages/ts-key-not-enum"
  },
  "scripts": {
    "build": "tspc",
    "dev": "clear; bun --watch ./scripts/scrapeMDNForKeyboardButtons.ts",
