{
  "name": "@evadev/backend-config",
  "type": "module",
  "version": "0.1.0",
  "description": "Reusable Effect tags to know which exact config params does effect/layer depends on and see if they weren't provided",
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@evadev/tsconfig": "workspace:^",
    "ts-namespace-import": "catalog:",
    "ts-patch": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@effect/platform": "catalog:",
    "effect": "catalog:"
  },
  "homepage": "https://github.com/nikelborm/effect-garden/tree/main/packages/backend-config#readme",
  "bugs": {
    "url": "https://github.com/nikelborm/effect-garden/issues",
    "email": "evadev@duck.com"
  },
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist-types/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./*.ts": "./src/*.ts",
    "./*": {
      "types": "./dist-types/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist-types/index.d.ts",
  "files": [
    "dist-types",
    "dist",
    "index.ts",
    "package.json",
    "src",
    "!**/*.spec.*",
    "!**/*.tsbuildinfo",
    "!**/scratchpad.*"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nikelborm/effect-garden.git",
    "directory": "packages/backend-config"
  },
  "scripts": {
    "build": "tspc",
    "dev": "bun --hot --no-clear-screen ./index.ts"
  },
  "author": {
    "name": "nikelborm",
    "email": "evadev@duck.com",
    "url": "https://github.com/nikelborm"
  },
  "contributors": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "maintainers": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": false
  }
}
