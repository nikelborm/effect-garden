{
  "name": "@evadev/joiners",
  "type": "module",
  "version": "0.1.0",
  "description": "Join 2 or more iterables as if it's SQL joins but with the level of type-safety you didn't know you need",
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@evadev/tsconfig": "workspace:*",
    "@stryker-mutator/vitest-runner": "catalog:",
    "@total-typescript/ts-reset": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "change-case": "catalog:",
    "ts-namespace-import": "catalog:",
    "ts-patch": "catalog:",
    "ts-toolbelt": "catalog:",
    "tstyche": "catalog:",
    "type-fest": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "outdent": "catalog:",
    "tsafe": "catalog:"
  },
  "homepage": "https://github.com/nikelborm/effect-garden/tree/main/packages/joiners#readme",
  "bugs": {
    "url": "https://github.com/nikelborm/effect-garden/issues",
    "email": "evadev@duck.com"
  },
  "keywords": [
    "joiner",
    "joiners",
    "joins",
    "sql",
    "typescript",
    "sql-like join",
    "iterable",
    "left-join",
    "right-join",
    "full-join",
    "inner-join",
    "cross-join",
    "left-anti-join",
    "right-anti-join",
    "full-anti-join",
    "left-outer-join",
    "right-outer-join",
    "full-outer-join",
    "join",
    "simple-join",
    "left-outer-anti-join",
    "right-outer-anti-join",
    "full-outer-anti-join",
    "left-exclusive-join",
    "left-join-excluding-inner",
    "right-exclusive-join",
    "right-join-excluding-inner",
    "full-exclusive-join",
    "full-join-excluding-inner",
    "cartesian",
    "cartesian-product"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nikelborm/effect-garden.git",
    "directory": "packages/joiners"
  },
  "scripts": {
    "build": "./scripts/build.sh",
    "coverage": "vitest run --coverage",
    "doc": "./scripts/generate_docs.sh",
    "docs": "./scripts/generate_docs.sh",
    "scratchpad": "node --use-strict ./scratchpad.ts",
    "test": "vitest --typecheck --watch",
    "test:mutate": "stryker run",
    "test-jsr": "tspc && jsr publish --dry-run",
    "test-once": "vitest --run",
    "watch-docs": "find src/ ./scripts/generate_docs.sh | entr -can ./scripts/generate_docs.sh"
  },
  "author": {
    "name": "nikelborm",
    "email": "evadev@duck.com",
    "url": "https://github.com/nikelborm"
  },
  "contributors": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "maintainers": [
    {
      "name": "nikelborm",
      "email": "evadev@duck.com",
      "url": "https://github.com/nikelborm"
    }
  ],
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "exports": {
    ".": {
      "types": "./dist-types/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./index": {
      "types": "./dist-types/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./index.js": {
      "types": "./dist-types/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist-types/src/index.d.ts",
  "files": [
    "dist",
    "src",
    "!dist/minified",
    "!**/*.tsbuildinfo",
    "!**/*.spec.*",
    "!**/scratchpad.*",
    ".github/FUNDING.yml"
  ]
}
